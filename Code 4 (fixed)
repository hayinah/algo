//quickselect
#include <iostream>
#include <vector>
#include <cstdlib>
#include <algorithm> // For swap
#include <ctime>     // For seeding rand()
#include <chrono>

using namespace std;

// Partition function remains the same
int partition(vector<int>& A, int p, int r) {
    int pivot = A[r];
    int q = p - 1;

    for (int j = p; j < r; j++) {
        if (A[j] < pivot) {
            q++;
            swap(A[q], A[j]);
        }
    }

    swap(A[q + 1], A[r]);
    return q + 1;
}

// Quickselect function remains the same
int quickselect(vector<int>& A, int p, int r, int i) {
    if (p == r) return A[p];

    int pivotIndex = p + rand() % (r - p + 1);
    swap(A[pivotIndex], A[r]);

    int q = partition(A, p, r);
    int k = q - p + 1;

    if (i == k) 
        return A[q];
    else if (i < k) 
        return quickselect(A, p, q - 1, i);
    else 
        return quickselect(A, q + 1, r, i - k);
}

int main() {
    srand(time(0));

    int n;
    cout << "Enter value of n: ";
    cin >> n;

    vector<int> A(n);

    // Fill with random values
    for (int j = 0; j < n; j++) {
        A[j] = rand() % 1000;
    }

    // Choose i (k-th smallest)
    int i;
    cout << "Enter i (which smallest element to find): ";
    cin >> i;

    cout << "Array: ";
    for (int j = 0; j < n; j++) cout << A[j] << " ";
    cout << endl;

    // START TIMER
    auto start = chrono::high_resolution_clock::now();

    int result = quickselect(A, 0, n - 1, i);

    // STOP TIMER
    auto stop = chrono::high_resolution_clock::now();

    auto duration = chrono::duration_cast<chrono::microseconds>(stop - start);

    cout << "The " << i << "th smallest element is: " << result << endl;
    cout << "Runtime: " << duration.count() << " microseconds" << endl;

    return 0;
}
