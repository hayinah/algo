#include <iostream>
#include <vector>
#include <cstdlib>
#include <algorithm> // For swap
#include <ctime>     // For seeding rand()

using namespace std;

// Partition function remains the same
int partition(vector<int>& A, int p, int r) {
    int pivot = A[r];
    int q = p - 1;

    for (int j = p; j < r; j++) {
        if (A[j] < pivot) {
            q++;
            swap(A[q], A[j]);
        }
    }

    swap(A[q + 1], A[r]);
    return q + 1;
}

// Quickselect function remains the same
int quickselect(vector<int>& A, int p, int r, int i) {
    if (p == r) return A[p];

    int pivotIndex = p + rand() % (r - p + 1);
    swap(A[pivotIndex], A[r]);

    int q = partition(A, p, r);
    int k = q - p + 1;

    if (i == k) 
        return A[q];
    else if (i < k) 
        return quickselect(A, p, q - 1, i);
    else 
        return quickselect(A, q + 1, r, i - k);
}

int main() {
    // Seed the random number generator
    srand(time(0));

    // Example: Find the 3rd smallest element (which is 7)
    int arr[] = {12, 3, 5, 7, 4, 19, 26};
    int n = sizeof(arr) / sizeof(arr[0]);
    vector<int> A(arr, arr + n);

    int i = 3; 
    cout << "The " << i << "rd smallest element is: " << quickselect(A, 0, n - 1, i) << endl;

    return 0;
}
