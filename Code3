//Longest Increasing Subsequence (LIS)
#include <iostream>
#include <vector>
using namespace std;

// Helper function to print the LIS using recursion
void printLIS(vector<int>& A, vector<int>& C, int i) {
    if (i < 0) return;              // Base case: no more elements
    printLIS(A, C, C[i]);           // Recursively go to previous index in LIS
    cout << A[i] << " ";            // Print current element AFTER recursion (correct order)
}

void algorithm3(vector<int>& A) {
    int N = A.size();

    vector<int> B(N, 1);   // B[i] = length of LIS ending at index i
    vector<int> C(N, -1);  // C[i] = index of previous element in LIS (for reconstruction)

    // 1. Build LIS lengths
    for (int i = 1; i < N; i++) {
        int m = 0;   // stores best LIS length found so far
        int n = -1;  // stores index of previous element in LIS

        // Looks at all previous elements
        for (int j = i - 1; j >= 0; j--) {
            // If A[j] can extend the increasing subsequence ending at A[i]
            if (A[j] < A[i] && B[j] > m) {
                m = B[j];   // update best length
                n = j;      // remember index
            }
        }

        B[i] = m + 1;   // LIS ending at i includes A[i]
        C[i] = n;       // store where it came from
    }

    //2.Find overall LIS 
    int maxLen = 1;  // length of longest LIS found
    int idx = 0;     // index where LIS ends

    for (int i = 0; i < N; i++) {
        if (B[i] > maxLen) {
            maxLen = B[i];
            idx = i;
        }
    }

    //3. Print LIS
    printLIS(A, C, idx);   // reconstruct sequence using C[]
    cout << endl;
}
