//Longest Increasing Subsequence (LIS)
#include <iostream>
#include <vector>
#include <chrono>
using namespace std;

// Helper function to print the LIS using recursion
void printLIS(vector<int>& A, vector<int>& C, int i) {
    if (i < 0) return;
    printLIS(A, C, C[i]);
    cout << A[i] << " ";
}

void algorithm3(vector<int>& A) {
    int N = A.size();
    if (N == 0) return;

    vector<int> B(N, 1);
    vector<int> C(N, -1);

    for (int i = 1; i < N; i++) {
        int m = 0;
        int n = -1;

        for (int j = i - 1; j >= 0; j--) {
            if (A[j] < A[i] && B[j] > m) {
                m = B[j];
                n = j;
            }
        }

        B[i] = m + 1;
        C[i] = n;
    }

    int maxLen = 1;
    int idx = 0;

    for (int i = 0; i < N; i++) {
        if (B[i] > maxLen) {
            maxLen = B[i];
            idx = i;
        }
    }

    //  CLEAR OUTPUT
    cout << "LIS: ";
    printLIS(A, C, idx);
    cout << endl;

    cout << "Length of LIS: " << maxLen << endl;
}

int main() {
    int n;
    cout << "Enter value of n: ";
    cin >> n;

    vector<int> A(n);

    for (int i = 0; i < n; i++) {
        A[i] = rand() % 1000;
    }

    //  Only print small arrays
    if (n <= 20) {
        cout << "Array: ";
        for (int i = 0; i < n; i++) cout << A[i] << " ";
        cout << endl;
    }

    auto start = chrono::high_resolution_clock::now();

    algorithm3(A);

    auto stop = chrono::high_resolution_clock::now();

    auto duration = chrono::duration_cast<chrono::milliseconds>(stop - start);

    cout << "Runtime: " << duration.count() << " ms" << endl;

    return 0;
}
