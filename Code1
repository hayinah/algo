#include <iostream>
#include <vector>
usign namespace std;

void dump(const vector<int>& B)  {
  for (int x : B) {
    if (x != 0) cout << x << " ";
  }
cout << endl;
}

void compute(vector<int>& A, vector <int>& B, int i) {
  if (i>= A.size()) {
      dump (B):
      return;
}

B[i] = 0;
compute(A, B, i + 1);

B[i] =  A[i];
compute(A, B, i + 1);
}

void algorithm1(vector<int>& A) {
  vector <int> B(A.size(), 0);
  compute (A, B, 0);
}
