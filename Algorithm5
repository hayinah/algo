Algorithm 5

Algorithm5 (A,N)

B <- Array[N]

j <- 1

i <- 1

while j < N - 1

i <- 1

while i < N-j

p <- i

m <- i+j-1

r <- min(i-1+2*j, N)

for u <- m+1 to p by -1 

B[u-1] <- A[u-1]

for v <- m to r-1 

B[r-|m-v] <- A[v+1]

for w <- p to r
if B[v] < B[u]
A[w] <- B[v--]

else 
A[w] <- B[u++]

i <- i + 2*j

j <- 2*j

return
