//Radix Sort
#include <iostream>
#include <vector>
#include <list>
#include <cmath>
using namespace std;

void algorithm2(vector<int>& A) {
    int N = A.size();                 // Total number of elements
    int size = sqrt(N) + 1;           // Number of buckets (~√N)

    vector<list<int>> Z(size);        // Create 'size' buckets (each is a list)

    //FIRST PASS: group by remainder (A[i] % size) 
    for (int i = 0; i < N; i++) {
        int bucketIndex = A[i] % size;   // Compute remainder
        Z[bucketIndex].push_back(A[i]); // Put element into corresponding bucket
    }

    // Collect elements back into A (in bucket order)
    int counter = 0;
    for (int i = 0; i < size; i++) {
        while (!Z[i].empty()) {
            A[counter++] = Z[i].front(); // Take front element from bucket
            Z[i].pop_front();            // Remove it from bucket
        }
    }

    // -------- SECOND PASS: group by division (A[i] / size) --------
    for (int i = 0; i < N; i++) {
        int bucketIndex = A[i] / size;   // Compute quotient
        Z[bucketIndex].push_back(A[i]); // Place into new bucket
    }

    // Collect elements back into A again
    counter = 0;
    for (int i = 0; i < size; i++) {
        while (!Z[i].empty()) {
            A[counter++] = Z[i].front(); // Copy back into array
            Z[i].pop_front();            // Remove from bucket
        }
    }
}
