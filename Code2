
#include <iostream>
#include <vector>
#include <list>
#include <cmath>
using namespace std;

void algorithm2(vector<int>& A) {
    int N = A.size();
    int size = sqrt(N) + 1;

    vector<list<int>> Z(size);

    // First pass (mod)
    for (int i = 0; i < N; i++) {
        Z[A[i] % size].push_back(A[i]);
    }

    int counter = 0;
    for (int i = 0; i < size; i++) {
        while (!Z[i].empty()) {
            A[counter++] = Z[i].front();
            Z[i].pop_front();
        }
    }

    // Second pass (division)
    for (int i = 0; i < N; i++) {
        Z[A[i] / size].push_back(A[i]);
    }

    counter = 0;
    for (int i = 0; i < size; i++) {
        while (!Z[i].empty()) {
            A[counter++] = Z[i].front();
            Z[i].pop_front();
        }
    }
}
