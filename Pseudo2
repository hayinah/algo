Algorithm2(A)

    Compute(A)
    Dump(A)
    return


Compute(A)

    size <- |√N| + 1                               // creates multiple buckets (lists)
    Z[1..size] <- EmptyList

    for i <- 1 to N
        append A[i] to end of Z[A[i] mod size]

    counter <- 1

    for i <- 1 to size
        while Z[i] is not empty
            A[counter] <- FirstElement(Z[i])
            counter++
            DeleteFirstElement(Z[i])

    for i <- 1 to N
        append A[i] to end of Z[A[i] / size]

    counter <- 1

    for i <- 1 to size
        while Z[i] is not empty
            A[counter] <- FirstElement(Z[i])
            counter++
            DeleteFirstElement(Z[i])

    return


Dump(A)

    for i <- 1 to N
        print A[i]

    return
