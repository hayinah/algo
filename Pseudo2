Algorithm2(A)

    Compute(A)
    Dump(A)
    return


Compute(A)

    size <- |√N| + 1                               // creates multiple buckets (lists)
    Z[1..size] <- EmptyList

    for i <- 1 to N
        append A[i] to end of Z[A[i] mod size]    // sorting based on a digit or component of the number

    counter <- 1

    for i <- 1 to size
        while Z[i] is not empty
            A[counter] <- FirstElement(Z[i])
            counter++
            DeleteFirstElement(Z[i])

    for i <- 1 to N
        append A[i] to end of Z[A[i] / size]       // sorting based on a DIFFERENT digit or component of the number
                                                  // processes digits in passes
    counter <- 1

    for i <- 1 to size
        while Z[i] is not empty                   // buckets are processed in order.. elements are written back into the array                                         // this partially sorts the array
            A[counter] <- FirstElement(Z[i])      // this partially sorts the array
            counter++
            DeleteFirstElement(Z[i])

    return


Dump(A)

    for i <- 1 to N
        print A[i]

    return
